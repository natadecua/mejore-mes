# ── DATABASE ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://mes_user:mes_pass@localhost:5432/mejore_mes

# ── ORDER TIME API ────────────────────────────────────────────────────────────
# Get from: Order Time Admin > Rest API > Create API Key
OT_BASE_URL=https://services.ordertime.com/api
OT_API_KEY=your_order_time_api_key_here
OT_EMAIL=api@mejore.com # dedicated API user email in OT
OT_PASSWORD=your_ot_password # or use DevKey below instead
# OT_DEV_KEY=your_dev_key # if you applied for DevKey, use instead of password

# ── QUICKBOOKS ONLINE ─────────────────────────────────────────────────────────
# Get from: developer.intuit.com > Dashboard > Your App > Keys & Credentials
QB_CLIENT_ID=your_qb_client_id
QB_CLIENT_SECRET=your_qb_client_secret
QB_REDIRECT_URI=http://localhost:3001/auth/qbo/callback
QB_SANDBOX=true # false for production
QB_REALM_ID= # populated after OAuth flow (company ID)
QB_ACCESS_TOKEN= # populated after OAuth flow (refresh daily)
QB_REFRESH_TOKEN= # populated after OAuth flow (100-day TTL)

# ── PYTHA WATCH ───────────────────────────────────────────────────────────────
# Folder PYTHA auto-exports BOM XML/CSV into. MES watches this folder.
PYTHA_WATCH_DIR=/mnt/pytha-exports # on Windows: C:/PYTHA/exports
PYTHA_PROCESSED_DIR=/mnt/pytha-processed

# ── QC PHOTO STORAGE ─────────────────────────────────────────────────────────
# Using local disk for POC. Swap for AWS S3 in production.
UPLOAD_DIR=./uploads/qc-photos
# AWS_S3_BUCKET=mejore-qc-photos
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-southeast-1

# ── AUTH ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=8h

# ── SERVER ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
